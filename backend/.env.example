# App
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=pos_db

# Database (production — Supabase / any PG connection string)
# When set, overrides all DB_HOST / DB_PORT / DB_USERNAME / DB_PASSWORD / DB_DATABASE above
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS (production: comma-separated origins or * for any)
CORS_ORIGIN=http://localhost:3000
